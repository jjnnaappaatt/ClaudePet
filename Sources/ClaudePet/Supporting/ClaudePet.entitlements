<plist version="1.0">
<dict>
    <!-- Intentionally NOT sandboxed: reading ~/.claude (a dotfolder at the home root,
         not a TCC-protected location) needs no entitlements when non-sandboxed.
         No com.apple.security.app-sandbox key on purpose. -->
</dict>
</plist>
